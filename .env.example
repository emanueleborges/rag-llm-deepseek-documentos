# =============================================================================
# Stack 100% GRATUITA (padrão recomendado)
# Ollama (LLM + embeddings) + Chroma + pypdf + BM25 — tudo local/self-hosted
# =============================================================================

LLM_PROVIDER=ollama
EMBEDDINGS_PROVIDER=ollama
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_LLM_MODEL=ibm/granite4:micro
# Modelo mais rápido: OLLAMA_LLM_MODEL=llama3.2:1b
OLLAMA_NUM_PREDICT=768
OLLAMA_NUM_CTX=4096
OLLAMA_TEMPERATURE=0

# Embeddings ONNX locais (alternativa gratuita, sem Ollama): pip install fastembed
# EMBEDDINGS_PROVIDER=fastembed
# FASTEMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- Serviços PAGOS — deixe vazio / não use ---
# Deepseek (API nuvem), Tavily (web search), LlamaParse (PDF cloud)
DEEPSEEK_API_KEY=
TAVILY_API_KEY=
LLAMA_CLOUD_API_KEY=

# Vector Store (Chroma local — gratuito)
VECTOR_STORE_PATH=./data/vector_store
CHROMA_COLLECTION_NAME=rag_documents
VECTOR_STORE_BACKEND=chroma
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=rag_documents
QDRANT_PORT=6333

# Document Processing (pypdf — gratuito)
DOCUMENTS_PATH=./data/documents
MAX_CHUNK_SIZE=1000
CHUNK_OVERLAP=100
PDF_PARSER=pypdf

# API / UI
API_HOST=127.0.0.1
API_PORT=8000
API_WORKERS=4
STREAMLIT_PORT=8501
CHAINLIT_PORT=8502
FEEDBACK_DIR=./data/feedback

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_agent.log
ENVIRONMENT=development
DEBUG=True

# Busca híbrida (BM25 + vetorial — gratuito)
HYBRID_SEARCH_ENABLED=true
HYBRID_FETCH_K=15
HYBRID_RRF_K=60
RERANK_TOP_K=5
RETRIEVAL_K=10
MAX_CONTEXT_CHARS=7000
RERANKER_ENABLED=false
CONTEXT_GRADER_ENABLED=false
LANGGRAPH_ENABLED=false
MAX_RETRIEVAL_RETRIES=1

# Langfuse — opcional, self-hosted gratuito (profile observability)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PORT=3000
LANGFUSE_NEXTAUTH_URL=http://localhost:3000
LANGFUSE_NEXTAUTH_SECRET=change-me-use-openssl-rand-hex-32
LANGFUSE_SALT=change-me-use-openssl-rand-hex-32
LANGFUSE_DB_PASSWORD=postgres
